# Copy to dashboard/.env and fill in your values

# Telegram Bot (required for auth)
BOT_TOKEN=your-telegram-bot-token
JWT_SECRET=your-random-secret-string
ALLOWED_USER_IDS=123456789

# Auth mode: set to "true" to require auth on every request
# (useful when using Tailscale or other tunnels without CF-Ray header)
AUTH_ALWAYS=false

# Optional: a custom hostname that bypasses Telegram auth
# Useful for LAN access via a secondary Cloudflare Tunnel hostname
# Example: LOCAL_HOSTNAME=dashboard.local.your-domain.com
LOCAL_HOSTNAME=

# --- Dashboard Server ---

# Dashboard port (default: 18790)
# FLOWBOARD_PORT=18790

# Dashboard bind address (default: 0.0.0.0)
# FLOWBOARD_HOST=0.0.0.0

# --- OpenClaw Integration ---

# OpenClaw workspace path (required)
# OPENCLAW_WORKSPACE=/home/youruser/.openclaw/workspace
OPENCLAW_WORKSPACE=

# Gateway URL (default: http://127.0.0.1:18789)
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# --- Canvas → Task Promote (Agent-Assisted) ---
# Requires OpenClaw webhooks to be enabled in openclaw.json:
#   { hooks: { enabled: true, token: "your-secret", path: "/hooks" } }

# Webhook token from your openclaw.json hooks.token
OPENCLAW_HOOKS_TOKEN=

# Delivery channel for promote notifications (default: last)
# Options: last, telegram, whatsapp, discord, slack, signal
OPENCLAW_DELIVER_CHANNEL=last

# Delivery target: chat ID (Telegram), phone (WhatsApp), channel ID (Discord)
# Leave empty to use the last active chat
OPENCLAW_DELIVER_TO=
