{
  "name": "flowboard",
  "version": "5.0.0",
  "description": "FlowBoard project workspaces, dashboard, and project-context hook for OpenClaw agents.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "screenshots:v5": "sh -c 'node scripts/v5-demo-fixture.mjs seed && node scripts/capture-v5-screenshots.mjs; status=$?; node scripts/v5-demo-fixture.mjs cleanup; exit $status'",
    "setup": "node scripts/setup.mjs",
    "plugin:lint": "node scripts/plugin-lint.mjs",
    "privacy:scan": "node scripts/privacy-scan.mjs",
    "release:check": "node scripts/release-check.mjs"
  },
  "homepage": "https://github.com/rasimme/FlowBoard",
  "keywords": [
    "openclaw",
    "flowboard",
    "project-management",
    "multi-agent",
    "hooks"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rasimme/FlowBoard.git"
  },
  "openclaw": {
    "install": {
      "defaultChoice": "git",
      "minHostVersion": ">=2026.5.20"
    },
    "compat": {
      "pluginApi": ">=2026.5.20"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": false
    },
    "hooks": [
      "./hooks/project-context"
    ]
  },
  "files": [
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "llms.txt",
    "hooks/**",
    "scripts/**",
    "snippets/**",
    "templates/**",
    "docs/**",
    "dashboard/**",
    ".env.example",
    "!dashboard/node_modules/**",
    "!dashboard/dist/**",
    "!dashboard/.env*",
    "!dashboard/dashboard-data.json",
    "!dashboard/.cloudflared/**",
    "!**/*.db",
    "!**/*.sqlite",
    "!**/*.log",
    "!docs/plans/**",
    "!docs/reviews/**",
    "!dashboard/projects/**",
    "!dashboard/test-workspace*/**",
    "!dashboard/test-*.js",
    "!dashboard/test-*.mjs",
    "!dashboard/test-fixtures/**",
    "!**/*.db-wal",
    "!**/*.db-shm",
    "!**/.hzl/**"
  ]
}
